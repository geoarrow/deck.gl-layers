{
  "name": "deck.gl-layers-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm --recursive --filter \"./packages/*\" build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "docs:build": "typedoc",
    "docs:publish": "gh-pages -d docs_build",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "repository": "https://github.com/geoarrow/deck.gl-layers",
  "author": "Kyle Barron <kylebarron2@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "gh-pages": "^6.1.0",
    "typedoc": "^0.25.4",
    "typedoc-plugin-missing-exports": "^2.1.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.25.0",
  "overrides": {
    "@deck.gl/aggregation-layers": "^9.3.0",
    "@deck.gl/core": "^9.3.0",
    "@deck.gl/extensions": "^9.3.0",
    "@deck.gl/geo-layers": "^9.3.0",
    "@deck.gl/layers": "^9.3.0",
    "@luma.gl/constants": "^9.3.0",
    "@luma.gl/core": "^9.3.0",
    "@luma.gl/engine": "^9.3.0",
    "@luma.gl/shadertools": "^9.3.0",
    "apache-arrow": ">=21"
  },
  "volta": {
    "node": "22.20.0"
  }
}
